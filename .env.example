# CodeSensei environment template.
# Copy to .env and fill values as needed. Empty .env (verbatim copy) is enough
# to reach the all-healthy state for the 001-infra-scaffold spec.

# === LLM / Embedding providers ===
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === Backend wiring (container-internal addresses) ===
DATABASE_URL=postgresql+asyncpg://codesensei:codesensei@postgres:5432/codesensei
REDIS_URL=redis://redis:6379/0
LOG_LEVEL=INFO

# === Postgres init (read by the postgres container) ===
POSTGRES_USER=codesensei
POSTGRES_PASSWORD=codesensei
POSTGRES_DB=codesensei

# === Host port overrides (compose binds on the host) ===
API_HOST_PORT=8000
FRONTEND_HOST_PORT=5173
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
OLLAMA_HOST_PORT=11434

# === Provider tuning (optional) ===
# Override the active provider's default model. Leave blank to use the
# adapter-baked default (OpenAI gpt-4o-mini, Anthropic claude-3-5-sonnet-latest,
# Ollama llama3.1:8b for chat; OpenAI text-embedding-3-small, Ollama
# nomic-embed-text for embeddings).
LLM_MODEL=
EMBEDDING_MODEL=
# Base URL for the Ollama HTTP API. The compose-internal default points at the
# `ollama` service from the `ollama` profile; override for host-side Ollama.
OLLAMA_BASE_URL=http://ollama:11434

# === PR review (003) ===
# Server-side cap on diff size (bytes). Over the limit → 413 payload_too_large.
REVIEW_MAX_DIFF_BYTES=
# Hard timeout (seconds) on the LLM call inside POST /api/review.
REVIEW_LLM_TIMEOUT_S=
# Optional GitHub PAT. Empty → only public PRs are fetchable via PR-URL mode.
GITHUB_TOKEN=

# === Ops & quality (004) ===
# Fernet key for credentials-at-rest in app_settings. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Empty → settings UI reads still work, but writes of secret fields are rejected.
MASTER_KEY=
# Healthz worker badge flips to "down" if the worker heartbeat is older than this.
WORKER_HEARTBEAT_STALE_S=
# Redis TTL applied to job results by arq. Defaults to 1 hour.
JOB_RESULT_TTL_S=
